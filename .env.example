# Copy this file to `.env` and set your real values (never commit `.env`).
OCM_API_KEY=replace_with_your_open_charge_map_key

# Postgres (optional). If both URLs below are unset, the API uses SQLite under ./data/local.db.
# Neon: Dashboard → Connect → copy the connection string (often includes ?sslmode=require).
# Paste as-is with the postgresql:// prefix; neon.tech / sslmode=require enable TLS for asyncpg.

# Production or default Neon branch (used when DATABASE_DEV_URL is not set).
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Optional: Neon dev branch (fork of production). When set, the API and scripts/seed_dev_db.py use this instead of DATABASE_URL.
# Workflow: point this at branch "dev" in the Neon dashboard (Connect). Mistakes here do not change production until you promote.
# Refresh dev from production: neon branches reset dev --parent --project-id <project_id>
# Promote dev to production: neon branches restore production dev --project-id <project_id> --preserve-under-name production_backup_<label>
# After promoting dev to production, point dev at the new prod head: neon branches restore dev production --project-id <project_id>
DATABASE_DEV_URL=

# Neon Auth (Better Auth) — base URL from Neon Console after enabling Auth, or from provision_neon_auth.
# JWT issuer/audience are the origin (scheme + host) of this URL; JWKS is {NEON_AUTH_BASE_URL}/.well-known/jwks.json
NEON_AUTH_BASE_URL=https://YOUR_ENDPOINT.neonauth.REGION.aws.neon.tech/neondb/auth

# Optional: used when the client does not send an Origin header (e.g. curl). Defaults to http://localhost:5000.
# Must be allowed in Neon Auth trusted domains / localhost settings when not using the browser.
NEON_AUTH_ORIGIN=http://localhost:5000

# API key used by the vehicle api to get information from a specific car model
VEHICLE_API_KEY=replace_with_vehicle_api_key
