# Copy this file to `.env` and set your real values (never commit `.env`).
OCM_API_KEY=replace_with_your_open_charge_map_key

# Postgres (optional). If both URLs below are unset, the API uses SQLite under ./data/local.db.
# Neon: Dashboard → Connect → copy the connection string (often includes ?sslmode=require).
# Paste as-is with the postgresql:// prefix; neon.tech / sslmode=require enable TLS for asyncpg.

# Production or default Neon branch (used when DATABASE_DEV_URL is not set).
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Optional: Neon dev branch. When set, the API and scripts/seed_dev_db.py use this instead of DATABASE_URL.
DATABASE_DEV_URL=